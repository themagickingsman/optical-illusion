"use client";
/**
 * SunEnvironment — Asteroid Command background renderer.
 * All visual parameters driven by SunConfig.
 * panEnabled=true adds mouse-drag panning with weighted inertia.
 */
import React, { useEffect, useRef } from "react";

// ─── Config ───────────────────────────────────────────────────────────────────
export interface SunConfig {
  // Sun disk
  sunSizePct:   number;   // % of min(W,H),  default 4
  sunInner:     string;   // hex colour,      default #FFFFFF
  sunOuter:     string;   // hex colour,      default #CC5500
  sunAlpha:     number;   // overall opacity  default 1.0

  // Glow 1 — close halo
  glow1Size:    number;   // × sunR,           default 3
  glow1Falloff: number;   // power curve exp,  default 0.5 (wide) … 4.0 (tight)
  glow1C1:      string;   // hex inner
  glow1A1:      number;   // alpha 0-1,        default 0.30
  glow1C2:      string;   // hex outer
  glow1A2:      number;   // alpha 0-1,        default 0.00

  // Glow 2 — large ambient
  glow2Size:    number;
  glow2Falloff: number;
  glow2C1:      string;
  glow2A1:      number;
  glow2C2:      string;
  glow2A2:      number;

  // Glow 3 — outermost corona
  glow3Size:    number;   // fraction of max(W,H), default 1.2
  glow3Falloff: number;   // default 0.3 (very wide)
  glow3C1:      string;   // hex inner
  glow3A1:      number;   // alpha, default 0.10
  glow3C2:      string;   // hex outer
  glow3A2:      number;   // alpha, default 0.00

  // Stars
  starCount:    number;   // default 1200
  starSeed:     number;   // increment to reseed
  starSize:     number;   // px, default 1.5
  starAlpha:    number;   // overall opacity,  default 0.85

  // Background gradient
  bgAngle:      number;   // 0-360 degrees, default 135
  bgC1:         string;   // hex stop 0%
  bgC2:         string;   // hex stop 50%
  bgC3:         string;   // hex stop 100%
  bgAlpha:      number;   // overall opacity,  default 1.0
}

export const DEFAULT_SUN_CONFIG: SunConfig = {
  sunSizePct: 4,
  sunInner:   "#FFFFFF",
  sunOuter:   "#CC5500",
  sunAlpha:   1.0,

  glow1Size:  3,
  glow1Falloff: 0.5,
  glow1C1:    "#FFE678",
  glow1A1:    0.30,
  glow1C2:    "#FFC840",
  glow1A2:    0.00,

  glow2Size:  0.55,
  glow2Falloff: 0.5,
  glow2C1:    "#FFE650",
  glow2A1:    0.22,
  glow2C2:    "#FF6400",
  glow2A2:    0.00,

  glow3Size:    1.2,
  glow3Falloff: 0.3,
  glow3C1:    "#FF6600",
  glow3A1:    0.10,
  glow3C2:    "#FF2200",
  glow3A2:    0.00,

  starCount:  1200,
  starSeed:   0,
  starSize:   1.5,
  starAlpha:  0.85,

  bgAngle:    135,
  bgC1:       "#050511",
  bgC2:       "#1a1a40",
  bgC3:       "#0d0d2b",
  bgAlpha:    1.0,
};

// ─── Helpers ──────────────────────────────────────────────────────────────────
interface Star { tx: number; ty: number; r: number; alpha: number; }

function makeStars(W: number, H: number, count: number, seed: number, size: number): Star[] {
  let s = (seed + 1) * 1664525 + 1013904223;
  const rng = () => { s ^= s << 13; s ^= s >> 17; s ^= s << 5; return (s >>> 0) / 4294967296; };
  return Array.from({ length: count }, () => ({
    tx:    rng() * W,
    ty:    rng() * H,
    r:     rng() < 0.15 ? size * 1.6 : size,
    alpha: rng() * 0.65 + 0.25,
  }));
}

export function hexToRgb(hex: string): [number, number, number] {
  const h = hex.replace("#", "");
  return [parseInt(h.slice(0,2),16), parseInt(h.slice(2,4),16), parseInt(h.slice(4,6),16)];
}

function angleToGradient(W: number, H: number, deg: number): [number,number,number,number] {
  const rad = ((deg - 90) * Math.PI) / 180;
  const dx  = Math.cos(rad), dy = Math.sin(rad);
  const len = Math.abs(W * dx) + Math.abs(H * dy);
  return [W/2 - dx*len/2, H/2 - dy*len/2, W/2 + dx*len/2, H/2 + dy*len/2];
}

/** Add stops across a gradient using a power-curve falloff for alpha.
 *  falloff < 1 = very gradual (stays bright far out)
 *  falloff = 1 = linear
 *  falloff > 1 = fast decay (tight)
 */
function addSmoothStops(
  grad: CanvasGradient,
  c1: string, a1: number,
  c2: string, a2: number,
  falloff = 0.5,
  stops?: number[],
) {
  if (!stops) {
    stops = Array.from({ length: 64 }, (_, i) => i / 63);
  }
  const [r1,g1,b1] = hexToRgb(c1);
  const [r2,g2,b2] = hexToRgb(c2);
  for (const t of stops) {
    const decay = Math.pow(1 - t, falloff);
    const a     = Math.max(0, a1 * decay + a2 * (1 - decay));
    const r     = Math.round(r1 + (r2-r1)*t);
    const g     = Math.round(g1 + (g2-g1)*t);
    const b     = Math.round(b1 + (b2-b1)*t);
    grad.addColorStop(t, `rgba(${r},${g},${b},${a.toFixed(3)})`);
  }
}

/**
 * Draw sun disk + all 3 glow layers at a given screen position.
 * Called directly from the game canvas draw loop for pixel-perfect alignment.
 */
export function drawSunLayers(
  ctx: CanvasRenderingContext2D,
  W: number, H: number,
  cx: number, cy: number,
  cfg: SunConfig,
): void {
  const sunR = Math.min(W, H) * (cfg.sunSizePct / 100);

  // Glow 2 — large ambient
  const ambR = Math.max(W, H) * cfg.glow2Size;
  const amb  = ctx.createRadialGradient(cx, cy, 0, cx, cy, ambR);
  addSmoothStops(amb, cfg.glow2C1, cfg.glow2A1, cfg.glow2C2, cfg.glow2A2, cfg.glow2Falloff);
  ctx.fillStyle = amb; ctx.fillRect(-W * 10, -H * 10, W * 20, H * 20);

  // Glow 3 — outermost corona
  const g3R = Math.max(W, H) * cfg.glow3Size;
  const g3  = ctx.createRadialGradient(cx, cy, 0, cx, cy, g3R);
  addSmoothStops(g3, cfg.glow3C1, cfg.glow3A1, cfg.glow3C2, cfg.glow3A2, cfg.glow3Falloff);
  ctx.fillStyle = g3; ctx.fillRect(-W * 10, -H * 10, W * 20, H * 20);

  // Sun disk
  ctx.globalAlpha = cfg.sunAlpha;
  const sg = ctx.createRadialGradient(cx - sunR*0.25, cy - sunR*0.25, 0, cx, cy, sunR);
  const [ir,ig,ib] = hexToRgb(cfg.sunInner);
  const [or,og,ob] = hexToRgb(cfg.sunOuter);
  sg.addColorStop(0.00, `rgb(${ir},${ig},${ib})`);
  sg.addColorStop(0.30, `rgb(${Math.round(ir*.9+or*.1)},${Math.round(ig*.9+og*.1)},${Math.round(ib*.9+ob*.1)})`);
  sg.addColorStop(0.60, `rgb(${Math.round(ir*.5+or*.5)},${Math.round(ig*.5+og*.5)},${Math.round(ib*.5+ob*.5)})`);
  sg.addColorStop(0.85, `rgb(${Math.round(ir*.1+or*.9)},${Math.round(ig*.1+og*.9)},${Math.round(ib*.1+ob*.9)})`);
  sg.addColorStop(1.00, `rgb(${or},${og},${ob})`);
  ctx.fillStyle = sg;
  ctx.beginPath(); ctx.arc(cx, cy, sunR, 0, Math.PI * 2); ctx.fill();
  ctx.globalAlpha = 1;

  // Glow 1 — close halo (full canvas fill — NO arc clip)
  const g1 = ctx.createRadialGradient(cx, cy, sunR*0.5, cx, cy, sunR*cfg.glow1Size);
  addSmoothStops(g1, cfg.glow1C1, cfg.glow1A1, cfg.glow1C2, cfg.glow1A2, cfg.glow1Falloff);
  ctx.fillStyle = g1;
  ctx.fillRect(-W * 10, -H * 10, W * 20, H * 20);
}

const PARALLAX = 0.05;

// ─── Component ────────────────────────────────────────────────────────────────
interface Props {
  config?:      SunConfig;
  sunX?:        number;      // fractional position, default 0.5
  sunY?:        number;
  animated?:    boolean;
  panEnabled?:  boolean;     // enable mouse drag + inertia, default false
  zoomEnabled?: boolean;     // enable mouse-wheel zoom centred on the sun, default false
  skipSun?:     boolean;     // if true, skip sun disk + glows (game renders them on its own canvas)
  sunPosRef?:   React.MutableRefObject<{x:number, y:number}>;  // direct screen position of the sun (from game's ws())
  worldPosRef?: React.MutableRefObject<{x:number, y:number}>;  // global world coordinates to parallax the starfield against
  mapPanRef?:   React.MutableRefObject<{x:number, y:number}>;  // externally synced map panning vector
  mapZoomRef?:  React.MutableRefObject<number>;                // externally synced map zooming scale
  style?:       React.CSSProperties;
  className?:   string;
}

export default function SunEnvironment({
  config      = DEFAULT_SUN_CONFIG,
  sunX        = 0.5,
  sunY        = 0.5,
  animated    = true,
  panEnabled  = false,
  zoomEnabled = false,
  skipSun     = false,
  sunPosRef,
  worldPosRef,
  mapPanRef,
  mapZoomRef,
  style,
  className,
}: Props) {
  const canvasRef    = useRef<HTMLCanvasElement>(null);
  const rafRef       = useRef<number>(0);
  const starsRef     = useRef<Star[]>([]);
  const driftRef     = useRef({ x: 0, y: 0 });   // slow auto-drift for star parallax
  const panRef       = useRef({ x: 0, y: 0 });   // user pan offset (world units)
  const velRef       = useRef({ x: 0, y: 0 });   // inertia velocity
  const zoomRef      = useRef(1.0);               // current zoom scale
  const draggingRef  = useRef(false);
  const lastPosRef   = useRef({ x: 0, y: 0 });
  const cfgRef       = useRef(config);
  cfgRef.current     = config;

  // Re-seed stars when relevant config changes
  useEffect(() => {
    const c = canvasRef.current;
    if (!c) return;
    starsRef.current = makeStars(c.width || 300, c.height || 300, config.starCount, config.starSeed, config.starSize);
  }, [config.starCount, config.starSeed, config.starSize]);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Resize observer
    const ro = new ResizeObserver(() => {
      const W = canvas.clientWidth, H = canvas.clientHeight;
      canvas.width = W; canvas.height = H;
      const cfg = cfgRef.current;
      starsRef.current = makeStars(W, H, cfg.starCount, cfg.starSeed, cfg.starSize);
    });
    ro.observe(canvas);
    canvas.width  = canvas.clientWidth  || 300;
    canvas.height = canvas.clientHeight || 300;
    starsRef.current = makeStars(canvas.width, canvas.height, config.starCount, config.starSeed, config.starSize);

    // ── Panning ───────────────────────────────────────────────────────────
    const cleanupFns: (() => void)[] = [];

    if (panEnabled) {
      canvas.style.cursor = "grab";

      const onDown = (e: MouseEvent) => {
        draggingRef.current = true;
        lastPosRef.current  = { x: e.clientX, y: e.clientY };
        velRef.current      = { x: 0, y: 0 };
        canvas.style.cursor = "grabbing";
      };
      const onMove = (e: MouseEvent) => {
        if (!draggingRef.current) return;
        const dx = e.clientX - lastPosRef.current.x;
        const dy = e.clientY - lastPosRef.current.y;
        panRef.current.x   -= dx;
        panRef.current.y   -= dy;
        velRef.current.x    = -dx;
        velRef.current.y    = -dy;
        lastPosRef.current  = { x: e.clientX, y: e.clientY };
      };
      const onUp = () => {
        draggingRef.current = false;
        canvas.style.cursor = zoomEnabled ? "grab" : "default";
      };

      canvas.addEventListener("mousedown", onDown);
      window.addEventListener("mousemove", onMove);
      window.addEventListener("mouseup",   onUp);
      cleanupFns.push(() => {
        canvas.removeEventListener("mousedown", onDown);
        window.removeEventListener("mousemove", onMove);
        window.removeEventListener("mouseup",   onUp);
      });
    }

    // ── Zoom (mouse wheel) ────────────────────────────────────────────────
    if (zoomEnabled) {
      const ZOOM_SPEED = 0.0012;
      // ZOOM_MIN = 0.5 because the canvas is painted at 200% of the container.
      // CSS scale(0.5) shrinks it back to exactly 100% — fully zoomed out.
      // Going below 0.5 would make the canvas smaller than the container, revealing
      // a black rectangle around it.
      const ZOOM_MIN   = 0.05;
      const ZOOM_MAX   = 50.0;

      const onWheel = (e: WheelEvent) => {
        e.preventDefault();
        const delta = e.deltaY * ZOOM_SPEED;
        zoomRef.current = Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, zoomRef.current * (1 - delta)));
      };

      canvas.addEventListener("wheel", onWheel, { passive: false });
      cleanupFns.push(() => canvas.removeEventListener("wheel", onWheel));
    }

    return () => {
      ro.disconnect();
      cancelAnimationFrame(rafRef.current);
      cleanupFns.forEach(fn => fn());
    };
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [panEnabled, zoomEnabled, sunX, sunY, animated]);

  // ── Draw loop (separate effect so config updates don't restart listeners) ──
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const draw = () => {
      const W   = canvas.width;
      const H   = canvas.height;
      const cfg = cfgRef.current;

      // Slow auto-drift (keeps stars alive even when not panning)
      if (animated) { driftRef.current.x += 0.18; driftRef.current.y += 0.07; }

      // Inertia: decelerate pan velocity when not dragging (weighty = 0.91 decay)
      if (!draggingRef.current) {
        velRef.current.x *= 0.91;
        velRef.current.y *= 0.91;
        if (Math.abs(velRef.current.x) < 0.04) velRef.current.x = 0;
        if (Math.abs(velRef.current.y) < 0.04) velRef.current.y = 0;
        panRef.current.x += velRef.current.x;
        panRef.current.y += velRef.current.y;
      }

      const pan = panRef.current;

      // ── 1. Background gradient (always full-screen, no zoom) ──────────
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      const [x1,y1,x2,y2] = angleToGradient(W, H, cfg.bgAngle);
      const bg = ctx.createLinearGradient(x1,y1,x2,y2);
      bg.addColorStop(0,   cfg.bgC1);
      bg.addColorStop(0.5, cfg.bgC2);
      bg.addColorStop(1,   cfg.bgC3);
      ctx.globalAlpha = cfg.bgAlpha;
      ctx.fillStyle   = bg;
      ctx.fillRect(0, 0, W, H);
      ctx.globalAlpha = 1;

      // Resolve sun centre in canvas-pixel space (no zoom transform in ctx).
      // Since the canvas scales to 200% width/height and centers at -50% to prevent gradient cutoff,
      // mapping raw screen pixels requires shifting them by the canvas padding (width/4).
      const mapDx = mapPanRef ? mapPanRef.current.x : 0;
      const mapDy = mapPanRef ? mapPanRef.current.y : 0;
      
      const sunCx = (sunPosRef ? sunPosRef.current.x + (W / 4) : W * sunX - pan.x) + mapDx;
      const sunCy = (sunPosRef ? sunPosRef.current.y + (H / 4) : H * sunY - pan.y) + mapDy;

      const zoom = mapZoomRef ? zoomRef.current * mapZoomRef.current : zoomRef.current;
      canvas.style.transform = "";
      canvas.style.transformOrigin = "";

      // ── 2. Stars (identity ctx transform — CSS zoom handles the visual scale) ──
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      const gamePx = worldPosRef ? worldPosRef.current.x : 0;
      const gamePy = worldPosRef ? worldPosRef.current.y : 0;
      
      const combinedX = (driftRef.current.x + pan.x + gamePx);
      const combinedY = (driftRef.current.y + pan.y + gamePy);
      
      ctx.fillStyle   = "#e2e8f0";
      for (const star of starsRef.current) {
        // Individual stars parallax geometrically harder the closer they are to the camera (larger radius)
        // radius goes 1.5 to 2.4 roughly. We use that as an intrinsic depth multiplier.
        const individualParallax = PARALLAX * (star.r * 0.5);
        const sx = ((star.tx - combinedX * individualParallax) % W + W) % W;
        const sy = ((star.ty - combinedY * individualParallax) % H + H) % H;
        ctx.globalAlpha = star.alpha * cfg.starAlpha;
        ctx.fillRect(sx, sy, star.r, star.r);
      }
      ctx.globalAlpha = 1;

      // ── 3. Sun disk + glows (scaled via native matrix to preserve background bounds) ──
      if (!skipSun) {
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.translate(sunCx, sunCy);
        ctx.scale(zoom, zoom);
        ctx.translate(-sunCx, -sunCy);
        drawSunLayers(ctx, W, H, sunCx, sunCy, cfg);
      }

      if (animated) rafRef.current = requestAnimationFrame(draw);
    };

    draw();
    return () => cancelAnimationFrame(rafRef.current);
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [sunX, sunY, animated, mapPanRef, mapZoomRef, sunPosRef, worldPosRef]);

  return (
    <canvas
      ref={canvasRef}
      className={className}
      style={{
        position: "absolute",
        // Extend 50% beyond the container on every side so radial gradients
        // never hit the canvas edge and appear masked/cut off.
        top: "-50%",
        left: "-50%",
        width: "200%",
        height: "200%",
        ...style,
      }}
    />
  );
}
