{
  "_meta": {
    "version": "1.0",
    "description": "ALLIANCES progression cost matrix. Defines how costs scale by tier, octave, and arc phase. All equipment costs in equipment_catalog.json are base (tier 1) values. This matrix defines multipliers for upgrades and unlocks.",
    "formula": "finalCost = baseCost × tierMultiplier[tier] × octaveFactor[octave] × arcPhaseModifier[phase]"
  },

  "tierMultipliers": {
    "1": 1.0,
    "2": 2.5,
    "3": 6.25,
    "4": 15.6,
    "5": 39.0
  },

  "octaveFactors": {
    "11": 1.0,
    "12": 4.0,
    "13": 16.0,
    "14": 64.0,
    "15": 256.0
  },

  "arcPhaseModifiers": {
    "venus-protocol":    { "costMod": 1.0,  "note": "Crash conditions. Everything costs exactly what it costs." },
    "forge-sequence":    { "costMod": 1.4,  "note": "Mid-build. Material scarcity on Venus. 40% markup." },
    "breakout":          { "costMod": 2.0,  "note": "Final push. Critical components at critical prices." },
    "alliance-formation":{ "costMod": 0.85, "note": "Alliance network active. Trade discounts apply." }
  },

