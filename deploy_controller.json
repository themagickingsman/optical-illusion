{
  "product": {
    "name": "Optical Illusions Platform",
    "urlPrefix": "optical-illusions",
    "description": "A showcase of high-performance WebGL optical illusions."
  },
  "repository": {
    "provider": "github",
    "owner": "themagickingsman",
    "repoName": "optical-illusion"
  },
  "hosting": {
    "provider": "vercel",
    "projectName": "optical-illusion",
    "framework": "nextjs"
  },
  "buildPipeline": {
    "outputMode": "server",
    "unoptimizedImages": true,
    "typescriptIgnoreErrors": true,
    "entryPoint": "WebsiteBuildCMS",
    "commands": {
      "install": "npm install",
      "build": "NEXT_TELEMETRY_DISABLED=1 NEXT_PUBLIC_BUILD=true next build",
      "deploy": "vercel --prod"
    }
  }
}
